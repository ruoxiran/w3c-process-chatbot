APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=postgresql://w3c:w3c@localhost:5432/w3c_process
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
LLM_BASE_URL=http://localhost:8001/v1
# The UI offers two providers: "bedrock" (this server default) and "kimi"
# (the OpenAI-compatible config below). Both sets of credentials stay
# server-side; the browser only sends a provider name, never a key. The
# request field is ``provider_choice``.
LLM_PROVIDER=bedrock
# Model for the active provider when it's ollama or bedrock (the
# openai-compatible cluster uses OPENAI_COMPATIBLE_MODEL instead). Claude
# models need the cross-region inference-profile prefix (``us.``); Nova/Qwen
# run on-demand without it.
LLM_MODEL=us.anthropic.claude-sonnet-5
# --- "Kimi" provider (OpenAI-compatible; Moonshot) ---
OPENAI_COMPATIBLE_BASE_URL=https://api.moonshot.cn/v1
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=moonshot-v1-32k
OPENAI_COMPATIBLE_TIMEOUT_SECONDS=120
# --- "Bedrock" provider (boto3 bedrock-runtime Converse) ---
BEDROCK_REGION=us-east-1
# Bedrock API key (bearer token) — generate one in the Amazon Bedrock console
# under "API keys". Works for GENERATION (bedrock-runtime). NOTE: it does NOT
# work for the Knowledge Base (bedrock-agent-runtime only supports SigV4) —
# see BEDROCK_KB_ENABLED below.
BEDROCK_API_KEY=
BEDROCK_TIMEOUT_SECONDS=120
# Answer output-token cap. 4096 keeps answers concise but leaves headroom for
# reasoning models (Claude adaptive thinking, DeepSeek R1) that think first.
BEDROCK_MAX_TOKENS=4096
# Bedrock Knowledge Base retrieval (augments the local corpus). REQUIRES SigV4
# IAM credentials (AWS access key + secret via env or ~/.aws) — the bearer
# BEDROCK_API_KEY above CANNOT authenticate bedrock-agent-runtime. Leave
# disabled unless you have those IAM credentials configured.
BEDROCK_KB_ENABLED=false
BEDROCK_KB_ID=
BEDROCK_KB_REGION=
BEDROCK_KB_MAX_RESULTS=8
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT_SECONDS=120
LLM_ROUTER_ENABLED=true
LLM_ROUTER_MODEL=
LLM_ROUTER_MIN_CONFIDENCE=0.55
W3C_API_ENABLED=true
W3C_API_BASE_URL=https://api.w3.org
W3C_API_TIMEOUT_SECONDS=12
W3C_API_CACHE_TTL_SECONDS=21600
W3C_API_CATALOG_PAGES=2
W3C_API_PERSISTENT_CACHE_ENABLED=true
W3C_API_CACHE_PATH=data/cache/w3c_api_cache.json
CORPUS_PATH=data/corpus/chunks.jsonl
COMPILED_CONTEXT_DIR=data/compiled/spec
COMPILED_CONTEXT_ENABLED=true
COMPILED_CONTEXT_MIN_ENTITY_CONFIDENCE=0.7
RETRIEVAL_DENSE_ENABLED=false
RETRIEVAL_EMBEDDING_CACHE_PATH=data/cache/retrieval_embeddings.jsonl
RETRIEVAL_DENSE_WEIGHT=24
RETRIEVAL_DENSE_CANDIDATE_LIMIT=80
EMBEDDING_MODEL=BAAI/bge-m3
OLLAMA_EMBEDDING_MODEL=qwen3-embedding:4b
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
SOURCE_ALLOWLIST=w3.org,api.w3.org,github.com/w3c/process,github.com/w3c/guide,w3c.github.io
INDEX_REFRESH_CRON=0 */6 * * *
REQUIRE_CITATIONS=true
ENABLE_MEMBER_ONLY_SOURCES=false
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
EXPOSE_OPENAPI_DOCS=true
